{
  "name": "@retrace/browser",
  "version": "0.1.0",
  "description": "Browser replay capture SDK for Retrace.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
